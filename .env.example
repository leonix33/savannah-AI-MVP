# Copy this file to .env and set your OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token_here
FACEBOOK_GRAPH_VERSION=v20.0
INSTAGRAM_BUSINESS_ID=your_instagram_business_id_here
TIKTOK_BUSINESS_ID=your_tiktok_business_id_here
AUTO_PUBLISH_MODE=false
LIVE_FACEBOOK_MODE=false
LIVE_SOCIAL_PUBLISHING=false
